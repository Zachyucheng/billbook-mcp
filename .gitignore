# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/web/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# web frontend — shared with desktop, except website-specific files
/web/src/components/marketing-page.tsx
/web/src/components/legal-page.tsx
/web/src/components/brand-mark.tsx
/web/src/components/feature-icons.tsx
/web/src/components/turnstile-widget.tsx
/web/src/lib/site.ts
/web/out/
/web/.next/
/web/.wrangler/

# development docs (kept local)
/docs/

# production build (desktop) - committed so fresh clones can run
/build
/dist-electron/
/billbook-app/

# dev data (auth store, workspace store)
/data/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
desktop/logs/
desktop/state/

# env files (can opt-in for committing if needed)
.env*

# python
__pycache__/
*.pyc

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
